generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./hub.db"
}

// ==================== HUB ====================

model HubApp {
  id           String   @id @default(cuid())
  name         String
  tagline      String
  description  String
  url          String
  icon         String
  gradient     String
  glowClass    String
  accentColor  String
  status       String   @default("live")
  previewImage String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model HubConfig {
  id             String   @id @default("singleton")
  heroTitle      String   @default("O'Brien")
  heroSubtitle   String   @default("Family Hub")
  heroCopy       String   @default("Our corner of the internet. Apps, games, and things we built — just for us.")
  heroIcon       String   @default("🏠")
  updatedAt      DateTime @updatedAt
}

// ==================== GERMAN LEARNING ====================

model GermanVideo {
  id           String         @id @default(cuid())
  youtubeId    String         @unique
  title        String
  channel      String
  skillLevel   String
  description  String?
  thumbnailUrl String?
  duration     Int?
  sortOrder    Int            @default(0)
  createdAt    DateTime       @default(now())
  segments     VideoSegment[]
  vocabItems   VideoVocab[]
}

model VideoSegment {
  id          String      @id @default(cuid())
  videoId     String
  video       GermanVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)
  startTime   Float
  endTime     Float
  germanText  String
  englishText String
  sortOrder   Int
}

model VideoVocab {
  id                 String      @id @default(cuid())
  videoId            String
  video              GermanVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)
  germanWord         String
  englishWord        String
  partOfSpeech       String?
  exampleSentence    String?
  exampleTranslation String?
}

model UserVocabList {
  id              String   @id @default(cuid())
  userName        String
  germanWord      String
  englishWord     String
  exampleSentence String?
  sourceVideoId   String?
  dateAdded       DateTime @default(now())
  lastReviewed    DateTime?
  confidence      Int      @default(0)
}

// ==================== RECIPES ====================

model RecipeTab {
  id        String       @id
  name      String
  icon      String       @default("🍽️")
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  items     RecipeItem[]
}

model RecipeItem {
  id               String         @id @default(cuid())
  tabId            String
  tab              RecipeTab      @relation(fields: [tabId], references: [id], onDelete: Cascade)
  title            String
  url              String?
  youtubeId        String?
  imageUrl         String?
  description      String?
  servings         Int?           @default(4)
  prepTime         Int?
  cookTime         Int?
  ingredientsJson  String?
  instructionsJson String?
  source           String?
  addedBy          String?
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  ratings          RecipeRating[]
}

model RecipeRating {
  id         String     @id @default(cuid())
  recipeId   String
  recipe     RecipeItem @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  memberName String
  stars      Int
  createdAt  DateTime   @default(now())
}

model ShoppingList {
  id         String   @id @default(cuid())
  memberName String
  itemsJson  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ==================== FAMILY MEMBERS (shared) ====================

model FamilyMember {
  id          String   @id @default(cuid())
  name        String
  emoji       String   @default("🎵")
  color       String   @default("#E91E8C")
  landingMode String   @default("classic")
  createdAt   DateTime @default(now())
}
