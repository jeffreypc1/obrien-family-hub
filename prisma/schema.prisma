generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./hub.db"
}

// ==================== HUB ====================

model HubApp {
  id           String   @id @default(cuid())
  name         String
  tagline      String
  description  String
  url          String
  icon         String
  gradient     String
  glowClass    String
  accentColor  String
  status       String   @default("live")
  previewImage String?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model HubConfig {
  id             String   @id @default("singleton")
  heroTitle      String   @default("O'Brien")
  heroSubtitle   String   @default("Family Hub")
  heroCopy       String   @default("Our corner of the internet. Apps, games, and things we built — just for us.")
  heroIcon       String   @default("🏠")
  updatedAt      DateTime @updatedAt
}

// ==================== GERMAN LEARNING ====================

model GermanVideo {
  id           String         @id @default(cuid())
  youtubeId    String         @unique
  title        String
  channel      String
  skillLevel   String
  description  String?
  thumbnailUrl String?
  duration     Int?
  sortOrder    Int            @default(0)
  createdAt    DateTime       @default(now())
  segments     VideoSegment[]
  vocabItems   VideoVocab[]
}

model VideoSegment {
  id          String      @id @default(cuid())
  videoId     String
  video       GermanVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)
  startTime   Float
  endTime     Float
  germanText  String
  englishText String
  sortOrder   Int
}

model VideoVocab {
  id                 String      @id @default(cuid())
  videoId            String
  video              GermanVideo @relation(fields: [videoId], references: [id], onDelete: Cascade)
  germanWord         String
  englishWord        String
  partOfSpeech       String?
  exampleSentence    String?
  exampleTranslation String?
}

model UserVocabList {
  id              String   @id @default(cuid())
  userName        String
  germanWord      String
  englishWord     String
  exampleSentence String?
  sourceVideoId   String?
  dateAdded       DateTime @default(now())
  lastReviewed    DateTime?
  confidence      Int      @default(0)
}

// ==================== RECIPES ====================

model RecipeTab {
  id        String       @id
  name      String
  icon      String       @default("🍽️")
  sortOrder Int          @default(0)
  createdAt DateTime     @default(now())
  items     RecipeItem[]
}

model RecipeItem {
  id               String         @id @default(cuid())
  tabId            String
  tab              RecipeTab      @relation(fields: [tabId], references: [id], onDelete: Cascade)
  title            String
  url              String?
  youtubeId        String?
  imageUrl         String?
  description      String?
  servings         Int?           @default(4)
  prepTime         Int?
  cookTime         Int?
  ingredientsJson  String?
  instructionsJson String?
  source           String?
  addedBy          String?
  tagsJson         String?
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  ratings          RecipeRating[]
}

model RecipeRating {
  id         String     @id @default(cuid())
  recipeId   String
  recipe     RecipeItem @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  memberName String
  stars      Int
  createdAt  DateTime   @default(now())
}

model ShoppingList {
  id         String   @id @default(cuid())
  memberName String
  itemsJson  String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ==================== PHOTOS ====================

model Photo {
  id            String         @id @default(cuid())
  imageUrl      String
  caption       String?
  uploadedBy    String
  albumId       String?
  dateTaken     String?
  location      String?
  camera        String?
  width         Int?
  height        Int?
  reactionsJson String?
  createdAt     DateTime       @default(now())
  comments      PhotoComment[]
}

model PhotoAlbum {
  id           String   @id @default(cuid())
  title        String
  description  String?
  coverPhotoId String?
  createdBy    String?
  createdAt    DateTime @default(now())
}

model PhotoComment {
  id         String   @id @default(cuid())
  photoId    String
  photo      Photo    @relation(fields: [photoId], references: [id], onDelete: Cascade)
  authorName String
  authorEmoji String?
  text       String
  createdAt  DateTime @default(now())
}

// ==================== RECOMMENDATIONS ====================

model Recommendation {
  id            String                    @id @default(cuid())
  category      String
  title         String
  description   String?
  imageUrl      String?
  linkUrl       String?
  linkLabel     String?
  recommendedBy String
  likes         Int                       @default(0)
  likedByJson   String?
  createdAt     DateTime                  @default(now())
  comments      RecommendationComment[]
}

model RecommendationComment {
  id               String         @id @default(cuid())
  recommendationId String
  recommendation   Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  authorName       String
  authorEmoji      String?
  text             String
  createdAt        DateTime       @default(now())
}

// ==================== EVENTS ====================

model CalendarEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  emoji       String   @default("📅")
  date        String
  startTime   String?
  endTime     String?
  recurring   String?
  createdBy   String?
  createdAt   DateTime @default(now())
}

model Trip {
  id          String      @id @default(cuid())
  title       String
  destination String
  startDate   String
  endDate     String
  status      String      @default("planned")
  coverImage  String?
  description String?
  createdBy   String?
  createdAt   DateTime    @default(now())
  items       TripItem[]
  photos      TripPhoto[]
}

model TripItem {
  id        String @id @default(cuid())
  tripId    String
  trip      Trip   @relation(fields: [tripId], references: [id], onDelete: Cascade)
  date      String
  time      String?
  endTime   String?
  type      String @default("activity")
  title     String
  details   String?
  address   String?
  url       String?
  sortOrder Int    @default(0)
}

model TripPhoto {
  id         String   @id @default(cuid())
  tripId     String
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  date       String
  imageUrl   String
  caption    String?
  uploadedBy String?
  createdAt  DateTime @default(now())
}

model LocalEvent {
  id          String   @id @default(cuid())
  title       String
  description String?
  date        String?
  venue       String?
  city        String
  url         String?
  source      String?
  imageUrl    String?
  createdAt   DateTime @default(now())
}

// ==================== TODOS ====================

model TodoItem {
  id           String   @id @default(cuid())
  title        String
  description  String?
  status       String   @default("todo")
  assignedTo   String
  createdBy    String
  dueDate      String?
  startedAt    String?
  completedAt  String?
  dollarAmount  Float?
  paidStatus    String?  @default("none")
  paidAt        String?
  paidMethod    String?
  paidBy        String?
  paidNote      String?
  exemptFromCap Int?     @default(0)
  fixedDueDate  Int?     @default(0)
  metDeadline   Int?
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
}

// ==================== FAMILY MEMBERS (shared) ====================

model FamilyMember {
  id          String   @id @default(cuid())
  name        String
  emoji       String   @default("🎵")
  color       String   @default("#E91E8C")
  landingMode String   @default("classic")
  createdAt   DateTime @default(now())
}
